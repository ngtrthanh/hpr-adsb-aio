# Copy this file to .env and fill in all values before running docker compose up

# ── Station location ──────────────────────────────────────────────────────────
FEEDER_TZ=Asia/Ho_Chi_Minh
FEEDER_LAT=
FEEDER_LONG=
FEEDER_ALT_M=           # altitude in metres above sea level

# ── RTL-SDR receiver ─────────────────────────────────────────────────────────
ADSB_SDR_SERIAL=        # serial number of the RTL-SDR dongle (e.g. 00000001)
ADSB_SDR_GAIN=          # gain value (e.g. 49.6), or "autogain"

# ── HPRadar / Ultrafeeder ─────────────────────────────────────────────────────
MULTIFEEDER_UUID=       # UUID for the HPRadar upstream feed

# ── Commercial aggregators ───────────────────────────────────────────────────
FD_FR24KEY=             # Flightradar24 sharing key
FD_RBFEEDER_SHARING_KEY_1=   # RadarBox key 1 (EXTRPI014979)
FD_RBFEEDER_SHARING_KEY_2=   # RadarBox key 2 (PGANRB501179)
FD_PIAWARE_FEEDER_ID=   # FlightAware feeder UUID
FD_PFC_SHARECODE=       # PlaneFinder share code

# ── Community aggregators ────────────────────────────────────────────────────
FD_AHUB_CLIENTKEY=      # ADSBHub client key
FD_OPENSKY_USERNAME=    # OpenSky Network username
FD_OPENSKY_SERIAL=      # OpenSky receiver serial (negative number)
